# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (replace with your actual cluster URI)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/voice-karar?retryWrites=true&w=majority

# ─── Authentication ───────────────────────────────────────────────────────────
# Use a long, random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=replace_with_a_very_long_random_secret
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your React frontend origin. Comma-separate multiple origins if needed.
# Example: https://voicekarar.app,https://www.voicekarar.app
CORS_ORIGIN=http://localhost:5173

# ─── App ──────────────────────────────────────────────────────────────────────
# Public base URL – used to construct shareable agreement links
# e.g.  https://voicekarar.app/share/a82hd73
APP_BASE_URL=http://localhost:5000
