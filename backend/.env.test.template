# Test Environment Variables
# Copy this to .env.test and customize as needed

# Server Configuration
NODE_ENV=test
PORT=8080

# Database
# Use separate test database - will be cleaned up after tests
MONGODB_URI=mongodb://localhost:27017/voice-karar-test

# JWT Configuration
JWT_SECRET=test-secret-key-do-not-use-in-production
JWT_EXPIRE=7d

# CORS Configuration (for test client access)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8081

# Logging
LOG_LEVEL=info

# Optional: AI Service Configuration
# AI_SERVICE_URL=http://localhost:5000
# AI_SERVICE_TIMEOUT=30000

# Optional: External Service Endpoints (for mocking)
# PAYMENT_SERVICE_URL=http://localhost:5001
# NOTIFICATION_SERVICE_URL=http://localhost:5002
