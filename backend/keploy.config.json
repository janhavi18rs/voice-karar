{
  "version": "2.0.0",
  "name": "voice-karar-backend",
  "kind": "express",
  "port": 8080,
  "testDirectory": "./test/keploy/tests",
  "mockDirectory": "./test/keploy/mocks",
  "proxyPort": 8081,
  "denoise": false,
  "globalTimeout": 30,
  "timeout": 30,
  "debug": false,
  "services": [
    {
      "name": "voice-karar-backend",
      "command": "npm run dev",
      "environmentVariables": {
        "NODE_ENV": "test",
        "PORT": "8080",
        "MONGODB_URI": "mongodb://localhost:27017/voice-karar-test",
        "JWT_SECRET": "test-secret-key-do-not-use-in-production"
      }
    }
  ],
  "skipXPath": [
    "**.timestamp",
    "**.createdAt",
    "**.updatedAt",
    "**.id",
    "**._id",
    "**.expiresAt"
  ],
  "captureHeader": [
    "authorization",
    "content-type",
    "accept",
    "user-agent"
  ],
  "passthrough": {
    "enabled": false
  }
}
